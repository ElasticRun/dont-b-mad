#!/usr/bin/env bash
# aieye-live-hook — installed by @aieye/live-hook
# Fire-and-forget: forks dispatch.js into background; exits foreground immediately.
# Hard ~2s ceiling is enforced inside dispatch.js (no external process time-limit utility — macOS-safe).
# Dependencies: bash, node>=18 on PATH (see README / `node .../dispatch.js --check-deps`).
# When AIEYE_LIVE_DEBUG is 1/true/yes, stderr is preserved (debug + WARN/ERROR lines).
DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_SCRIPT="$DIR/../lib/dispatch.js"

if [ "${1:-}" = "--check-deps" ]; then
  exec node "$NODE_SCRIPT" --check-deps
fi

case "${AIEYE_LIVE_DEBUG:-}" in
  1|true|TRUE|yes|Yes|YES) ( node "$NODE_SCRIPT" "$@" >/dev/null || true ) & ;;
  *) ( node "$NODE_SCRIPT" "$@" >/dev/null 2>&1 || true ) & ;;
esac
exit 0
